rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-uid lockdown: authenticated users may only read/write their own saves.
    // All sub-collections under users/{uid}/ are covered by the recursive wildcard.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny the legacy flat saves collection entirely.
    // The app writes saves under users/{uid}/saves/{autoId} (addDoc + updateDoc by id);
    // no path under this top-level saves/ collection is valid.
    match /saves/{id} {
      allow read, write: if false;
    }

    // Public feature flags — world-readable, write-only via Firebase console.
    match /config/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Catch-all: deny everything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
