#!/bin/sh

# ── Full gate at push boundary (Protocol 36) ──────────────────────────────────
# Runs the complete gate including browser checks (boot-smoke + render-check)
# before anything reaches origin. CI runs the same gate — parity holds here.
npm run gate || exit 1
# ── End pre-push gate ─────────────────────────────────────────────────────────

# ── Local-artifact backup NUDGE (Protocol 48) — NEVER a blocker ───────────────
# A fail-safe reminder to refresh the private archive when the local-only
# artifacts (library/, planning/, memory) have changed since the last sync. It
# can never fail or block a push: the script always exits 0, and the trailing
# `|| true` is a second guarantee that even a crashing node cannot break the
# push. On a machine without the private backup it stays completely silent.
node scripts/backup-nudge.js || true
# ── End backup nudge ──────────────────────────────────────────────────────────

# ── Queue-drift NUDGE (Protocol 50) — NEVER a blocker ─────────────────────────
# A fail-safe reminder listing `type: project` memories that don't appear
# referenced in QUEUE.md, so a plan that only ever lived in memory becomes
# visible. Same fail-safe shape as the backup nudge above: always exits 0,
# and `|| true` is a second guarantee. Silent on a machine with no memory
# store, or when nothing looks unqueued.
node scripts/queue-drift-check.js || true
# ── End queue-drift nudge ─────────────────────────────────────────────────────
