#!/bin/sh

# ── Protocol 1 guard: cache bump required only when served/precached files change ──
# Branch-agnostic (Protocol 43): the staged sw.js CACHE_NAME must DIFFER from THIS
# branch's own HEAD value whenever a served/precached file is staged. The full logic
# lives in Node (scripts/cache-bump-guard.js) so it is exercised behaviourally by the
# gate (Suite 30) instead of by grepping shell text. Non-served commits skip; an
# unreachable HEAD baseline warns and passes (fail-safe). See Protocol 1.
node scripts/cache-bump-guard.js || exit 1
# ── End Protocol 1 guard ──────────────────────────────────────────────────────

# ── Q3 — Secret scan: block staged private keys and Google API keys ──────────
STAGED_DIFF=$(git diff --cached)
# Check for private key blocks in added lines (all staged files)
if printf '%s\n' "$STAGED_DIFF" | grep -E '^\+[^+]' | grep -qE 'BEGIN [A-Z0-9 ]*PRIVATE KEY'; then
  echo ""
  echo "  [FAIL]  Secret detected: private key block found in staged diff."
  echo "  Remove the private key and commit again."
  echo ""
  exit 1
fi
# Check for Google API key pattern — exclude js/services/cloud.js (contains a legitimate public Firebase web API key)
STAGED_NO_CLOUD=$(printf '%s\n' "$STAGED_DIFF" | awk '/^diff --git /{if(/cloud\.js/)in_cloud=1;else in_cloud=0} !in_cloud{print}')
if printf '%s\n' "$STAGED_NO_CLOUD" | grep -E '^\+[^+]' | grep -qE 'AIza[0-9A-Za-z_-]{35}'; then
  echo ""
  echo "  [FAIL]  Secret detected: Google API key (AIza...) in staged diff (non-cloud.js file)."
  echo "  Public Firebase web keys belong in js/services/cloud.js only. Remove secrets before committing."
  echo ""
  exit 1
fi
echo "  [PASS]  No secrets detected in staged diff."
# ── End Q3 ───────────────────────────────────────────────────────────────────

# ── Fast gate: lint + format + tests (Protocol 36) ───────────────────────────
# Browser checks (boot-smoke + render-check) run via the pre-push hook instead.
npm run gate:fast || exit 1
# ── End gate ─────────────────────────────────────────────────────────────────
